{
  "name": "keynote",
  "version": "0.0.1",
  "description": "Tech Sharing keynote",
  "homepage": "https://keynote.brandonxiang.top/",
  "scripts": {
    "dev": "npm-run-all --parallel dev:svelte dev:reveal",
    "dev:svelte": "svelteup -w",
    "dev:reveal": "reveal-md md -w",
    "build": "pnpm run build:svelte && pnpm run build:reveal && pnpm run seo && pnpm run sw",
    "build:svelte": "svelteup",
    "build:reveal": "reveal-md md --static dist",
    "seo": "node scripts/generate-seo-assets.js",
    "sw": "workbox generateSW"
  },
  "author": {
    "name": "brandonxiang",
    "email": "brandon.xiang@gmail.com",
    "web": "https://github.com/brandonxiang"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brandonxiang/keynote.git"
  },
  "bugs": {
    "url": "https://github.com/brandonxiang/keynote/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "reveal-md": "^6.1.4",
    "svelteup": "^5.2.1",
    "workbox-cli": "^7.4.1"
  },
  "pnpm": {
    "overrides": {
      "basic-ftp": "^5.2.2",
      "dompurify": "^3.4.0",
      "esbuild": "^0.25.0",
      "glob": "^10.5.0",
      "ip-address": "^10.1.1",
      "lodash": "^4.18.1",
      "lodash-es": "^4.18.1",
      "mermaid": "^11.15.0",
      "path-to-regexp": "0.1.13",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "qs": "^6.14.1",
      "serialize-javascript": "^7.0.5",
      "tmp": "^0.2.4",
      "uuid": "^11.1.1",
      "ws": "^8.20.1"
    }
  },
  "license": "MIT",
  "dependencies": {
    "@lucide/svelte": "^1.16.0",
    "html-to-image": "^1.11.13",
    "jszip": "^3.10.1",
    "svelte": "^5.55.9"
  },
  "packageManager": "pnpm@11.3.0"
}